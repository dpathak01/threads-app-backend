{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",

    "module": "nodenext",
    "target": "es2022",
    "moduleResolution": "nodenext",

    "types": ["node"],

    "strict": true,
    "isolatedModules": true,

    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}